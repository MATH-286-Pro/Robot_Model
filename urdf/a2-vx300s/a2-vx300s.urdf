  <!-- Joints -->
  <joint name="left_finger_joint" type="prismatic">
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="0" upper="0.0425" velocity="0.1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="vx300s_fingers_link"/>
    <child link="vx300s_left_carriage"/>
    <dynamics damping="10.1" friction="0.1"/>
  </joint>

  <joint name="right_finger_joint" type="prismatic">
    <axis xyz="0 -1 0"/>
    <limit effort="10" lower="0" upper="0.0425" velocity="0.1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="vx300s_fingers_link"/>
    <child link="vx300s_right_carriage"/>
    <dynamics damping="10.1" friction="0.1"/>
    <mimic joint="left_finger_joint" multiplier="1" offset="0"/>
  </joint>


  <joint name="left_finger_passive_joint" type="prismatic" dont_collapse="true">
    <axis xyz="0 1 0"/>
    <limit effort="10" lower="0" upper="0.01" velocity="0.1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="vx300s_left_carriage"/>
    <child link="vx300s_left_finger_link"/>
    <dynamics damping="10.1" friction="0.1"/>
  </joint>

  <joint name="right_finger_passive_joint" type="prismatic" dont_collapse="true">
    <axis xyz="0 -1 0"/>
    <limit effort="10" lower="0" upper="0.01" velocity="0.1"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="vx300s_right_carriage"/>
    <child link="vx300s_right_finger_link"/>
    <dynamics damping="10.1" friction="0.1"/>
    <mimic joint="left_finger_passive_joint" multiplier="1" offset="0"/>
  </joint>
  

  <joint name="fix_eef_link" type="fixed" dont_collapse="true">
    <axis xyz="1 0 0"/>
    <origin rpy="0 0 0" xyz="0.14 0 0"/>
    <parent link="vx300s_fingers_link"/>
    <child link="eef_link"/>
  </joint>

  <joint name="joint_gopro" type="fixed" dont_collapse="true">
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="-0.0522 0.0 0.09"/>
    <parent link="vx300s_fingers_link"/>
    <child link="gopro"/>
  </joint>

  <joint name="umi_base_top_joint" type="fixed" dont_collapse="true">
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    <parent link="vx300s_fingers_link"/>
    <child link="umi_base_top"/>
  </joint>

  <joint name="fix_linear_rail_and_left_mirror" type="fixed" dont_collapse="true">
    <parent link="umi_base_top" />
    <child link="left_mirror" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="fix_linear_rail_and_right_mirror" type="fixed" dont_collapse="true">
    <parent link="umi_base_top" />
    <child link="right_mirror" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="umi_base_bottom_joint" type="fixed" dont_collapse="true">
    <axis xyz="0 1 0"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>
    <parent link="vx300s_fingers_link"/>
    <child link="umi_base_bottom"/>
  </joint>
    
  <joint name="fix_left_tape_and_left_finger" type="fixed" dont_collapse="true">
    <parent link="vx300s_left_finger_link" />
    <child link="left_tape" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="fix_right_tape_and_right_finger" type="fixed" dont_collapse="true">
    <parent link="vx300s_right_finger_link" />
    <child link="right_tape" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

</robot>
