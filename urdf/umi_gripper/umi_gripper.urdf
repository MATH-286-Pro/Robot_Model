      <geometry>
        <mesh filename="meshes/assets/umi_base_grip.stl" />
      </geometry>
      <material name="white">
        <color rgba="1.00000000 1.00000000 1.00000000 1.00000000"/>
      </material>
    </visual>
    <inertial>
      <origin xyz="-0.058 0 -0.057" rpy="0 0.12 0" />
      <mass value="0.046" />
      <inertia 
        ixx="0.000037724167"
        iyy="0.000041169500"
        izz="0.000008228833"
        ixy="0" 
        ixz="0" 
        iyz="0" 
