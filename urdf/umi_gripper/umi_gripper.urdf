<?xml version="1.0"?>
<robot name="umi_gripper">


  <material name="orange">
    <color rgba="1 0.27 0.0 1" />
  </material>

  <material name="dark_gray">
    <color rgba="0.1 0.1 0.1 1" />
  </material>

  <material name="white">
    <color rgba="1 1 1 1" />
  </material>

  <material name="black">
    <color rgba="0 0 0 1" />
  </material>

  <link name="world">
    <inertial>
