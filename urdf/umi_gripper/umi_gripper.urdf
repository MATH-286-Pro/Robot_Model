  </link>

  <link name="linear_rail">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="meshes/assets/linear_rail.stl" />
      </geometry>
      <material name="light_gray">
        <color rgba="0.60000392 0.60000392 0.60000392 1.00000000"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.070"/>
      <inertia ixx="0.000131496458" iyy="0.000000718958" izz="0.000131722500" ixy="0" ixz="0" iyz="0"/>
